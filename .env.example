# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe → Developers → API Keys (Publishable Key only)
# Get this from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key

# Stripe Secret Key (backend only - never commit this!)
# Get this from: https://dashboard.stripe.com/apikeys
# Store in Supabase secrets: supabase secrets set STRIPE_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY=sk_live_your_secret_key

# Stripe Webhook Secret (backend only - never commit this!)
# Get this after creating a webhook endpoint in Stripe Dashboard
# Store in Supabase secrets: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
